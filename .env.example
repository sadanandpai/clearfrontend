# Copy to `.env` and fill in values from your Appwrite project and Redis provider.
# cp .env.example .env

# Appwrite — public endpoint (same for cloud or self-hosted)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite — Project ID (Settings → General in Appwrite console)
NEXT_APPWRITE_PROJECT=

# Appwrite — API key with database access (use a dev key locally; never commit real keys)
NEXT_APPWRITE_KEY=

# Redis Cloud (or compatible) password — must match `src/server/config/redis.config.ts` host/port
NEXT_REDIS_PASSWORD=
